<?xml version="1.0"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro" name="three_wheel_camera_car">

  <xacro:property name="wheel_radius" value="0.06"/>
  <xacro:property name="wheel_width" value="0.035"/>
  <xacro:property name="wheel_separation" value="0.30"/>
  <xacro:property name="base_z" value="0.09"/>

  <material name="body_blue"><color rgba="0.05 0.20 0.55 1"/></material>
  <material name="dark_gray"><color rgba="0.05 0.05 0.05 1"/></material>
  <material name="camera_black"><color rgba="0.01 0.01 0.01 1"/></material>
  <material name="glass"><color rgba="0.10 0.55 0.90 0.85"/></material>
  <material name="metal"><color rgba="0.55 0.55 0.58 1"/></material>
  <material name="caster_light"><color rgba="0.82 0.82 0.82 1"/></material>

  <xacro:macro name="box_inertial" params="m x y z">
    <inertial>
      <mass value="${m}"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="${m*(y*y+z*z)/12.0}" ixy="0" ixz="0" iyy="${m*(x*x+z*z)/12.0}" iyz="0" izz="${m*(x*x+y*y)/12.0}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="cylinder_inertial" params="m r l">
    <inertial>
      <mass value="${m}"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="${m*(3*r*r+l*l)/12.0}" ixy="0" ixz="0" iyy="${m*(3*r*r+l*l)/12.0}" iyz="0" izz="${m*r*r/2.0}"/>
    </inertial>
  </xacro:macro>

  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${base_z}" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.34 0.22 0.08"/></geometry>
      <material name="body_blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.34 0.22 0.08"/></geometry>
    </collision>
    <xacro:box_inertial m="1.25" x="0.34" y="0.22" z="0.08"/>
  </link>

  <link name="left_wheel_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
    </collision>
    <xacro:cylinder_inertial m="0.14" r="${wheel_radius}" l="${wheel_width}"/>
  </link>

  <link name="right_wheel_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
    </collision>
    <xacro:cylinder_inertial m="0.14" r="${wheel_radius}" l="${wheel_width}"/>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel_link"/>
    <origin xyz="-0.055 0.15 -0.030" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel_link"/>
    <origin xyz="-0.055 -0.15 -0.030" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="front_caster_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.035"/></geometry>
      <material name="caster_light"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.035"/></geometry>
      <surface><friction><ode><mu>0.05</mu><mu2>0.05</mu2></ode></friction></surface>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.00002" ixy="0" ixz="0" iyy="0.00002" iyz="0" izz="0.00002"/>
    </inertial>
  </link>

  <joint name="front_caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_caster_link"/>
    <origin xyz="0.18 0 -0.055" rpy="0 0 0"/>
  </joint>

  <!-- Front-down camera. Gazebo camera optical axis follows the camera_link +X axis. -->
  <link name="camera_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.055 0.075 0.045"/></geometry>
      <material name="camera_black"/>
    </visual>
    <visual>
      <origin xyz="0.033 0 0" rpy="0 1.57079632679 0"/>
      <geometry><cylinder radius="0.018" length="0.012"/></geometry>
      <material name="glass"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.055 0.075 0.045"/></geometry>
    </collision>
    <xacro:box_inertial m="0.05" x="0.055" y="0.075" z="0.045"/>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <!-- x forward, z up. Positive pitch around Y aims the +X camera axis downward. -->
    <origin xyz="0.31 0 0.155" rpy="0 0.95 0"/>
  </joint>

  <gazebo reference="base_link"><material>Gazebo/Blue</material></gazebo>
  <gazebo reference="left_wheel_link"><material>Gazebo/Black</material><mu1>1.5</mu1><mu2>1.5</mu2></gazebo>
  <gazebo reference="right_wheel_link"><material>Gazebo/Black</material><mu1>1.5</mu1><mu2>1.5</mu2></gazebo>
  <gazebo reference="front_caster_link"><material>Gazebo/White</material><mu1>0.05</mu1><mu2>0.05</mu2></gazebo>
  <gazebo reference="camera_link"><material>Gazebo/Black</material></gazebo>

  <gazebo reference="camera_link">
    <sensor type="camera" name="front_down_camera">
      <always_on>true</always_on>
      <update_rate>30</update_rate>
      <visualize>true</visualize>
      <camera name="front_down_camera">
        <horizontal_fov>1.3962634</horizontal_fov>
        <image><width>640</width><height>480</height><format>R8G8B8</format></image>
        <clip><near>0.05</near><far>8.0</far></clip>
        <noise><type>gaussian</type><mean>0.0</mean><stddev>0.004</stddev></noise>
      </camera>
      <plugin name="gazebo_ros_camera" filename="libgazebo_ros_camera.so">
        <alwaysOn>true</alwaysOn>
        <updateRate>30.0</updateRate>
        <cameraName>camera</cameraName>
        <imageTopicName>image_raw</imageTopicName>
        <cameraInfoTopicName>camera_info</cameraInfoTopicName>
        <frameName>camera_link</frameName>
        <hackBaseline>0.0</hackBaseline>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo>
    <plugin name="diff_drive_controller" filename="libgazebo_ros_diff_drive.so">
      <alwaysOn>true</alwaysOn>
      <updateRate>100</updateRate>
      <leftJoint>left_wheel_joint</leftJoint>
      <rightJoint>right_wheel_joint</rightJoint>
      <wheelSeparation>${wheel_separation}</wheelSeparation>
      <wheelDiameter>${2.0 * wheel_radius}</wheelDiameter>
      <wheelAcceleration>2.5</wheelAcceleration>
      <wheelTorque>2.0</wheelTorque>
      <commandTopic>cmd_vel</commandTopic>
      <odometryTopic>odom</odometryTopic>
      <odometryFrame>odom</odometryFrame>
      <robotBaseFrame>base_footprint</robotBaseFrame>
      <publishTf>true</publishTf>
      <publishWheelTF>false</publishWheelTF>
      <publishWheelJointState>true</publishWheelJointState>
      <legacyMode>false</legacyMode>
      <odometrySource>world</odometrySource>
    </plugin>
  </gazebo>

</robot>
